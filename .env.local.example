# HomeSync environment.
# Copy this file to `.env.local` and fill in the values.
# `.env.local` is gitignored and must NEVER be committed.

# Neon serverless PostgreSQL connection string (Neon dashboard -> Connection Details).
# Use the pooled connection string; keep ?sslmode=require.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Auth.js (Google OAuth). Generate AUTH_SECRET with: openssl rand -base64 33
AUTH_SECRET=""
# From Google Cloud Console -> APIs & Services -> Credentials -> OAuth client ID (Web).
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Comma-separated allowlist of the two Google account emails allowed to sign in.
ALLOWED_EMAILS="you@gmail.com,partner@gmail.com"
